# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=4010
# Origem do front-end (CORS / cookies de sessão)
APP_ORIGIN=http://localhost:5173

# ─── Admin / Auth ───────────────────────────────────────────
# Chave do portal admin — mínimo 16 caracteres
ADMIN_PORTAL_KEY=
# Secret de assinatura de sessão (legado) — mínimo 32 caracteres
ADMIN_SESSION_SECRET=
# Seed de admins em JSON. Ex.:
# [{"email":"admin@exemplo.com","displayName":"Admin","password":"trocar","role":"ceo","botIds":[],"isActive":true}]
ADMIN_USERS_JSON=
# Duração da sessão em minutos (30–20160). Padrão: 10080 (7 dias)
SESSION_TTL_MINUTES=10080

# ─── Banco de dados (Supabase/Postgres) ─────────────────────
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/postgres
# Validação estrita do certificado TLS do Postgres (true/false)
DATABASE_SSL_STRICT=false
# CA própria do provedor (PEM inline ou caminho do arquivo). Opcional
DATABASE_CA_CERT=

# ─── Segurança ──────────────────────────────────────────────
# Chave para encriptar tokens de bot em repouso (AES-256-GCM) — mínimo 16 chars
# Opcional: se ausente, tokens ficam em texto puro (legado)
BOT_TOKEN_ENC_KEY=

# ─── Cloudflare Turnstile (captcha) ─────────────────────────
# Secret de validação server-side. Em dev use a chave de teste:
# 1x0000000000000000000000000000000AA
TURNSTILE_SECRET=
